{
    "testName": "User CRUD Integration Tests",
    "resourceUri": "/users",
    "tableName": "app_user",
    "keyRowName": "username",
    "existingKey": "frank",
    "newKey": "bob",
    "populateSqlPath": "testsql/user/populate-app-user.sql",
    "testData": {
        "FailNotEnoughFields": {
            "inputJson": { "username": "bob" },
            "expectedJson": {}
        },
        "FailUpdateNotExists": {
            "inputJson": { "displayname": "frank69", "weight": 65.33 },
            "expectedJson": {}
        },
        "ReadOneExisting": {
            "inputJson": {},
            "expectedJson": {
                "username": "frank",
                "displayname": "Frank",
                "role": "admin",
                "weight": 65.2,
                "areWorkoutsPublic": true
            }
        },
        "ReadFiveExisting": {
            "inputJson": {},
            "expectedJson": [
                {
                    "username": "frank",
                    "displayname": "Frank",
                    "role": "admin",
                    "weight": 65.2,
                    "areWorkoutsPublic": true
                },
                {
                    "username": "frank2",
                    "displayname": "Frank",
                    "role": "admin",
                    "weight": 65.2,
                    "areWorkoutsPublic": true
                },
                {
                    "username": "frank3",
                    "displayname": "Frank",
                    "role": "admin",
                    "weight": 65.2,
                    "areWorkoutsPublic": true
                },
                {
                    "username": "frank4",
                    "displayname": "Frank",
                    "role": "admin",
                    "weight": 65.2,
                    "areWorkoutsPublic": true
                },
                {
                    "username": "frank5",
                    "displayname": "Frank",
                    "role": "admin",
                    "weight": 65.2,
                    "areWorkoutsPublic": true
                }
            ]
        },
        "ReadThirdAndFourthExisting": {
            "inputJson": {},
            "expectedJson": [
                {
                    "username": "frank3",
                    "displayname": "Frank",
                    "role": "admin",
                    "weight": 65.2,
                    "areWorkoutsPublic": true
                },
                {
                    "username": "frank4",
                    "displayname": "Frank",
                    "role": "admin",
                    "weight": 65.2,
                    "areWorkoutsPublic": true
                }
            ]
        },
        "CreateOneUniqueMinimumFields": {
            "inputJson": {
                "username": "bob",
                "displayname": "Bob",
                "weight": 65.2
            },
            "expectedJson": {
                "username": "bob",
                "displayname": "Bob",
                "role": "default",
                "weight": 65.2,
                "areWorkoutsPublic": false
            }
        },
        "ReplaceOneExisting": {
            "inputJson": {
                "username": "frank",
                "displayname": "Frank69",
                "role": "default",
                "weight": 75,
                "areWorkoutsPublic": true
            },
            "expectedJson": {
                "username": "frank",
                "displayname": "Frank69",
                "role": "default",
                "weight": 75,
                "areWorkoutsPublic": true
            }
        },
        "ReplaceOneExistingMinumumFields": {
            "inputJson": {
                "username": "frank",
                "displayname": "Frank"
            },
            "expectedJson": {
                "username": "frank",
                "displayname": "Frank",
                "role": "default",
                "weight": null,
                "areWorkoutsPublic": false
            }
        },
        "ReplaceOneUnique": {
            "inputJson": {
                "username": "bob",
                "displayname": "Bob",
                "role": "admin",
                "weight": 72.4,
                "areWorkoutsPublic": true
            },
            "expectedJson": {
                "username": "bob",
                "displayname": "Bob",
                "role": "admin",
                "weight": 72.4,
                "areWorkoutsPublic": true
            }
        },
        "ReplaceOneExistingNewKey": {
            "inputJson": {
                "username": "bob",
                "displayname": "Bob",
                "role": "default",
                "weight": 75,
                "areWorkoutsPublic": true
            },
            "expectedJson": {
                "username": "bob",
                "displayname": "Bob",
                "role": "default",
                "weight": 75,
                "areWorkoutsPublic": true
            }
        },
        "UpdateOneExisting": {
            "inputJson": { "displayname": "frank69", "weight": 65.33 },
            "expectedJson": {
                "username": "frank",
                "displayname": "frank69",
                "role": "admin",
                "weight": 65.33,
                "areWorkoutsPublic": true
            }
        },
        "UpdateOneExistingMinimumFields": {
            "inputJson": { "username": "frank" },
            "expectedJson": {
                "username": "frank",
                "displayname": "Frank",
                "role": "admin",
                "weight": 65.2,
                "areWorkoutsPublic": true
            }
        },
        "UpdateOneExistingNewKey": {
            "inputJson": {
                "username": "bob",
                "displayname": "Bob",
                "role": "default",
                "weight": 75,
                "areWorkoutsPublic": true
            },
            "expectedJson": {
                "username": "bob",
                "displayname": "Bob",
                "role": "default",
                "weight": 75,
                "areWorkoutsPublic": true
            }
        }
    }
